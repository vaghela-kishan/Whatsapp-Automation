# Copy to `.env` and adjust. NEVER commit the real `.env`.

# --- Application ---
PROJECT_NAME=AI Support Platform
VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_use_a_long_random_value_in_env
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_ALGORITHM=HS256

# --- Dashboard login (the single admin who can sign in) ---
# CHANGE both before any public deploy — this is your dashboard password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Database ---
# Local development (zero-install):
DATABASE_URL=sqlite:///./dev.db
# Production / Postgres (uncomment and fill in):
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/support
SQL_ECHO=false

# --- CORS (comma-separated) ---
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- Business / branding (how the AI introduces itself) ---
BUSINESS_NAME=Aurora Store
BUSINESS_TAGLINE=Premium lifestyle & electronics
SUPPORT_HOURS=Mon–Sat, 9am–8pm IST
ASSISTANT_NAME=Ava

# --- AI provider: "mock" (no key, fully offline) or "gemini" ---
AI_PROVIDER=mock
# Get a key at https://aistudio.google.com/app/apikey, then set AI_PROVIDER=gemini
GEMINI_API_KEY=
# Use a current model — "gemini-1.5-*" names are retired.
GEMINI_MODEL=gemini-2.5-flash-lite

# --- WhatsApp provider: "mock" (in-app simulator) or "meta" (Cloud API) ---
WHATSAPP_PROVIDER=mock
WHATSAPP_VERIFY_TOKEN=dev-verify-token
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# App Secret from Meta → App Settings → Basic. Enables webhook signature
# verification (recommended in production). Leave empty to skip.
WHATSAPP_APP_SECRET=

# Seed demo data (customers/orders/FAQs) on startup when the DB is empty.
SEED_ON_STARTUP=true
